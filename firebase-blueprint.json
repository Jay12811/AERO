{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about the authenticated user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "Folder": {
      "title": "Archive Folder",
      "description": "A container for neural data entries.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "Document": {
      "title": "Neural Document",
      "description": "A single piece of data stored in an archive folder.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "folderId": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "folderId", "ownerId", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles."
    },
    "/folders/{folderId}": {
      "schema": "Folder",
      "description": "Stores archive folders."
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "Stores neural documents."
    }
  }
}
